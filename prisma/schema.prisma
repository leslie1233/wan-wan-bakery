generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Product {
  id           String               @id @default(cuid())
  slug         String               @unique
  image        String
  priceCents   Int                  @default(0)
  published    Boolean              @default(true)
  sortOrder    Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  translations ProductTranslation[]
}

model ProductTranslation {
  id          String  @id @default(cuid())
  productId   String
  locale      String
  name        String
  category    String
  description String
  highlights  String
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
}

model PromotionSettings {
  id           String                 @id @default("default")
  active       Boolean                @default(true)
  updatedAt    DateTime               @updatedAt
  translations PromotionTranslation[]
  tiers        PromotionTier[]
}

model PromotionTranslation {
  id         String            @id @default(cuid())
  settingsId String            @default("default")
  locale     String
  eyebrow    String
  title      String
  intro      String
  cartHint   String
  settings   PromotionSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)

  @@unique([settingsId, locale])
}

model PromotionTier {
  id              String                    @id @default(cuid())
  settingsId      String                    @default("default")
  minQuantity     Int
  discountPercent Int
  sortOrder       Int                       @default(0)
  settings        PromotionSettings         @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  translations    PromotionTierTranslation[]
}

model PromotionTierTranslation {
  id     String        @id @default(cuid())
  tierId String
  locale String
  label  String
  tier   PromotionTier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@unique([tierId, locale])
}

model SiteSettings {
  id             String   @id @default("default")
  phone          String
  phoneE164      String
  whatsappNumber String
  paynowNumber   String   @default("")
  updatedAt      DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum LoyaltyTransactionType {
  EARN
  REDEEM
  REFERRAL_BONUS
  ADJUSTMENT
}

model Customer {
  id            String               @id @default(cuid())
  email         String               @unique
  name          String
  phone         String               @default("")
  passwordHash  String
  referralCode  String               @unique
  referredById  String?
  referredBy    Customer?            @relation("Referrals", fields: [referredById], references: [id])
  referrals     Customer[]           @relation("Referrals")
  loyaltyPoints Int                  @default(0)
  createdAt     DateTime             @default(now())
  orders        Order[]
  transactions  LoyaltyTransaction[]
}

model Order {
  id                      String      @id @default(cuid())
  orderNumber             String      @unique
  customerId              String?
  customer                Customer?   @relation(fields: [customerId], references: [id])
  guestEmail              String?
  guestName               String?
  guestPhone              String?
  status                  OrderStatus @default(PENDING)
  subtotalCents           Int
  bulkDiscountCents       Int         @default(0)
  firstOrderDiscountCents Int         @default(0)
  referralDiscountCents   Int         @default(0)
  pointsRedeemedCents     Int         @default(0)
  totalCents              Int
  pointsEarned            Int         @default(0)
  pointsRedeemed          Int         @default(0)
  referralCodeUsed        String?
  pickupDate              String?
  notes                   String?
  createdAt               DateTime    @default(now())
  items                   OrderItem[]
}

model OrderItem {
  id                String @id @default(cuid())
  orderId           String
  order             Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productSlug       String
  productName       String
  quantity          Int
  unitCents         Int
  lineSubtotalCents Int
}

model LoyaltyTransaction {
  id          String                 @id @default(cuid())
  customerId  String
  customer    Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type        LoyaltyTransactionType
  points      Int
  orderId     String?
  note        String?
  createdAt   DateTime               @default(now())
}

model RewardsSettings {
  id                        String   @id @default("default")
  active                    Boolean  @default(true)
  ownerEmail                String   @default("sdksdk77@hotmail.com")
  fromEmail                 String   @default("Wan Wan Bakery <orders@wanwanbakery.com>")
  firstOrderDiscountPercent Int      @default(10)
  referralDiscountPercent   Int      @default(10)
  referrerPointsReward      Int      @default(500)
  pointsPerDollar           Int      @default(1)
  pointsRedemptionRate      Int      @default(100)
  pointsRedemptionValueCents Int     @default(500)
  updatedAt                 DateTime @updatedAt
}
