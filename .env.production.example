# Production database (Neon) — copy to .env.production (gitignored)
# Use DIRECT connection ending in /neondb (not neondb_dev)
# Only for: npm run db:push:prod or npm run db:seed:prod
# Vercel production site uses pooler URL in Vercel dashboard (same neondb database)

DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
