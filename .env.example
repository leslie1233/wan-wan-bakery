# Public site URL used for canonical URLs, sitemap, and structured data
NEXT_PUBLIC_SITE_URL=https://www.wanwanbakery.com

# Google Analytics 4 measurement ID (optional)
NEXT_PUBLIC_GA_ID=

# Google Search Console HTML tag verification code (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Admin backend database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=wan-wan-bakery-local-dev-secret

# Default admin account created by `npm run db:seed`
ADMIN_EMAIL=admin@wanwanbakery.com
ADMIN_PASSWORD=changeme123
