{
  "name": "wan-wan-bakery",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:push:prod": "dotenv -e .env.production -- prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:prod": "dotenv -e .env.production -- tsx prisma/seed.ts",
    "db:create-dev": "dotenv -e .env.production -- node scripts/create-dev-database.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "next": "14.2.5",
    "next-auth": "^5.0.0-beta.31",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "prisma": "^5.22.0",
    "tsx": "^4.19.4",
    "typescript": "5.5.4"
  }
}
