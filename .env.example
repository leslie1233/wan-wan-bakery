# Public site URL used for canonical URLs, sitemap, and structured data
NEXT_PUBLIC_SITE_URL=https://www.wanwanbakery.com

# Google Analytics 4 measurement ID (optional)
NEXT_PUBLIC_GA_ID=

# Google Search Console HTML tag verification code (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Instagram profile URL or @handle (optional — shows footer/contact link when set)
# Example: https://www.instagram.com/wanwanbakery/  or  @wanwanbakery
NEXT_PUBLIC_INSTAGRAM_URL=

# DEVELOPMENT database (local .env + .env.local)
# Use Neon DIRECT connection in .env for: npm run db:push, npm run db:seed
# Use Neon POOLER connection in .env.local for: npm run dev
# Database name should be neondb_dev (not production neondb)
DATABASE_URL=

# Copy .env.production.example to .env.production for production schema updates:
# npm run db:push:prod

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=wan-wan-bakery-local-dev-secret

# Default admin account created by `npm run db:seed`
ADMIN_EMAIL=admin@wanwanbakery.com
ADMIN_PASSWORD=changeme123

# Email notifications (Resend — https://resend.com)
RESEND_API_KEY=
OWNER_EMAIL=sdksdk77@hotmail.com
